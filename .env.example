# Ngrok (for receiving Twilio webhooks)
MESSAGING_API_NGROK_AUTHTOKEN=your_ngrok_authtoken
MESSAGING_API_NGROK_DOMAIN=your-domain.ngrok-free.app

# Google AI - Gemini API (used by pydantic-ai internally as GOOGLE_API_KEY)
GEMINI_API_KEY=your_gemini_api_key

# Twilio
MESSAGING_API_TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ===================================
# Unified Environment Variables
# (Used by both Docker and local development)
# ===================================

# Ngrok (optional - only needed for custom domains on paid plan)
# For free tier, leave blank and ngrok will generate a random URL
# NGROK_AUTHTOKEN=

# Google AI - Gemini API
GOOGLE_API_KEY=your_gemini_api_key

# Twilio
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_PHONE_NUMBER=+15551234567

# Application
LOG_LEVEL=DEBUG
LOG_FORMATTER=text
